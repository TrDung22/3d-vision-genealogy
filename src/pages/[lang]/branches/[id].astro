---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { EDGE_TYPES } from '../../../lib/graph';
import { LOCALES, t, type Lang } from '../../../lib/i18n';

export async function getStaticPaths() {
  const branches = await getCollection('branches');
  return LOCALES.flatMap((lang) =>
    branches.map((b) => ({ params: { lang, id: b.id }, props: { branch: b } })),
  );
}

const { branch } = Astro.props;
const lang = Astro.params.lang as Lang;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = `${base}/${lang}`;

const loc = branch.data.i18n?.[lang];
const tagline = loc?.tagline ?? branch.data.tagline;
const description = loc?.description ?? branch.data.description;

const nodes = (await getCollection('nodes'))
  .filter((n) => n.data.branch.id === branch.id)
  .sort((a, b) => a.data.year - b.data.year);

const laneTitle = new Map(branch.data.lanes.map((l) => [l.id, l.title]));
const allNodes = await getCollection('nodes');
const shortOf = new Map(allNodes.map((n) => [n.id, n.data.short]));
---

<Base title={branch.data.title} lang={lang} description={tagline}>
  <header>
    <p>
      <span class="chip">
        <span class="dot" style={`background:${branch.data.color}`}></span>
        {t(lang, 'branch.label')} ·{' '}
        {branch.data.status === 'active' ? t(lang, 'branches.growing') : t(lang, 'branches.planned')}
      </span>
    </p>
    <h1>{branch.data.title}</h1>
    <p class="tagline">{tagline}</p>
    <p style="max-width: 760px;">{description}</p>
  </header>

  <h2>{t(lang, 'branch.timeline')} ({nodes.length} {t(lang, 'table.nodes')})</h2>
  <ol class="timeline">
    {
      nodes.map((n) => (
        <li>
          <div class="year">{n.data.year}</div>
          <div class="body">
            <h3>
              <a href={`${root}/nodes/${n.id}/`}>{n.data.short}</a>
              {laneTitle.has(n.data.lane) && <span class="badge">{laneTitle.get(n.data.lane)}</span>}
            </h3>
            <p>{n.data.problem}</p>
            {n.data.relations.length > 0 && (
              <p class="muted rels">
                {n.data.relations
                  .map((r) => `${EDGE_TYPES[r.type].label} ${shortOf.get(r.node.id) ?? r.node.id}`)
                  .join(' · ')}
              </p>
            )}
          </div>
        </li>
      ))
    }
  </ol>

  <p><a href={`${root}/branches/`}>{t(lang, 'branch.all')}</a></p>
</Base>

<style>
  .tagline {
    color: var(--ink-2);
    font-size: 1.05rem;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    border-left: 2px solid var(--baseline);
  }

  .timeline li {
    display: flex;
    gap: 1.25rem;
    padding: 0.9rem 0 0.9rem 1.25rem;
    position: relative;
  }

  .timeline li::before {
    content: '';
    position: absolute;
    left: -6px;
    top: 1.5rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--surface);
    border: 2px solid var(--muted);
  }

  .timeline .year {
    flex: none;
    width: 3.2rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    padding-top: 0.15rem;
  }

  .timeline h3 {
    margin: 0 0 0.25rem;
  }

  .timeline .badge {
    margin-left: 0.6em;
  }

  .timeline p {
    margin: 0.25rem 0;
    font-size: 0.95rem;
  }

  .timeline .rels {
    font-size: 0.85rem;
  }
</style>
