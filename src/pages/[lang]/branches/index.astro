---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { LOCALES, t, type Lang } from '../../../lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = `${base}/${lang}`;

const branches = (await getCollection('branches')).sort((a, b) => a.data.order - b.data.order);
const nodes = await getCollection('nodes');
const countOf = (branchId: string) => nodes.filter((n) => n.data.branch.id === branchId).length;
const taglineOf = (b: (typeof branches)[number]) =>
  b.data.i18n?.[lang]?.tagline ?? b.data.tagline;
const titleOf = (b: (typeof branches)[number]) => b.data.i18n?.[lang]?.title ?? b.data.title;
---

<Base title={t(lang, 'nav.branches')} lang={lang}>
  <h1>{t(lang, 'branches.title')}</h1>
  <p class="muted" style="max-width: 720px;">{t(lang, 'branches.intro')}</p>

  <div class="branch-grid">
    {
      branches.map((b) => (
        <a class="panel branch-card" href={`${root}/branches/${b.id}/`} style={`--branch-color:${b.data.color}`}>
          <div class="bar" />
          <h2>{titleOf(b)}</h2>
          <p class="tagline">{taglineOf(b)}</p>
          <p class="muted">
            {countOf(b.id)} {t(lang, 'table.nodes')} ·{' '}
            <span class="badge">
              {b.data.status === 'active' ? t(lang, 'branches.growing') : t(lang, 'branches.planned')}
            </span>
          </p>
        </a>
      ))
    }
  </div>
</Base>

<style>
  .branch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .branch-card {
    display: block;
    color: inherit;
    transition: border-color 0.15s;
  }

  .branch-card:hover {
    text-decoration: none;
    border-color: var(--branch-color);
  }

  .branch-card .bar {
    height: 4px;
    width: 44px;
    border-radius: 2px;
    background: var(--branch-color);
    margin-bottom: 0.8rem;
  }

  .branch-card h2 {
    margin: 0 0 0.3rem;
    font-size: 1.15rem;
  }

  .branch-card .tagline {
    color: var(--ink-2);
    font-size: 0.92rem;
  }
</style>
