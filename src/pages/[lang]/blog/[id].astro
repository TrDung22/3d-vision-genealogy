---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { LOCALES, t, type Lang } from '../../../lib/i18n';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return LOCALES.flatMap((lang) =>
    posts.map((p) => ({ params: { lang, id: p.id }, props: { post: p } })),
  );
}

const { post } = Astro.props;
const lang = Astro.params.lang as Lang;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = `${base}/${lang}`;
const { Content } = await render(post);

const relatedNodes = await Promise.all(post.data.nodes.map((ref) => getEntry(ref)));
const dateLocale = { en: 'en-US', vi: 'vi-VN', ja: 'ja-JP' }[lang];
const fmtDate = (d: Date) =>
  d.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={post.data.title} lang={lang} description={post.data.description}>
  <article class="post">
    <header>
      <h1>{post.data.title}</h1>
      <p class="muted">{fmtDate(post.data.date)}</p>
      {
        relatedNodes.filter(Boolean).length > 0 && (
          <p class="muted">
            {t(lang, 'blog.related')}{' '}
            {relatedNodes
              .filter(Boolean)
              .map((n, i) => (
                <>
                  {i > 0 && ' · '}
                  <a href={`${root}/nodes/${n!.id}/`}>{n!.data.short}</a>
                </>
              ))}
          </p>
        )
      }
    </header>
    <div class="prose">
      <Content />
    </div>
    <p><a href={`${root}/blog/`}>{t(lang, 'blog.all')}</a></p>
  </article>
</Base>

<style>
  .post {
    max-width: 760px;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 8px;
  }
</style>
