---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { LOCALES, t, type Lang } from '../../../lib/i18n';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = `${base}/${lang}`;

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const dateLocale = { en: 'en-US', vi: 'vi-VN', ja: 'ja-JP' }[lang];
const fmtDate = (d: Date) =>
  d.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={t(lang, 'blog.title')} lang={lang}>
  <h1>{t(lang, 'blog.title')}</h1>
  <p class="muted" style="max-width: 720px;">{t(lang, 'blog.intro')}</p>

  {
    posts.length === 0 ? (
      <p class="muted">{t(lang, 'blog.none')}</p>
    ) : (
      <ul class="post-list">
        {posts.map((p) => (
          <li class="panel">
            <h2>
              <a href={`${root}/blog/${p.id}/`}>{p.data.title}</a>
            </h2>
            <p class="muted date">{fmtDate(p.data.date)}</p>
            <p>{p.data.description}</p>
          </li>
        ))}
      </ul>
    )
  }
</Base>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .post-list h2 {
    margin: 0;
    font-size: 1.2rem;
  }

  .post-list .date {
    font-size: 0.85rem;
    margin: 0.2rem 0 0.5rem;
  }

  .post-list p {
    margin: 0.2rem 0;
  }
</style>
