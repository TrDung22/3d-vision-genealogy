---
import { getCollection, getEntry } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { EDGE_TYPES } from '../../../lib/graph';
import { LOCALES, t, type Lang } from '../../../lib/i18n';

export async function getStaticPaths() {
  const nodes = await getCollection('nodes');
  return LOCALES.flatMap((lang) =>
    nodes.map((n) => ({ params: { lang, id: n.id }, props: { entry: n } })),
  );
}

const { entry } = Astro.props;
const lang = Astro.params.lang as Lang;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const root = `${base}/${lang}`;

const branch = await getEntry(entry.data.branch);
const all = await getCollection('nodes');
const byId = new Map(all.map((n) => [n.id, n]));

// outgoing: what this node says about older nodes
const outgoing = entry.data.relations
  .map((r) => ({ type: r.type, note: r.note, other: byId.get(r.node.id) }))
  .filter((r) => r.other);

// incoming: what newer nodes say about this one
const incoming = all.flatMap((n) =>
  n.data.relations
    .filter((r) => r.node.id === entry.id)
    .map((r) => ({ type: r.type, note: r.note, other: n })),
);

const post = entry.data.post ? await getEntry(entry.data.post) : null;

const LINK_LABELS: Record<string, string> = {
  arxiv: 'arXiv',
  paper: 'Paper',
  project: 'Project page',
  code: 'Code',
};
---

<Base title={entry.data.short} lang={lang} description={entry.data.problem}>
  <article>
    <header class="node-header">
      <p>
        <span class="chip">
          <span class="dot" style={`background:${branch?.data.color}`}></span>
          <a href={`${root}/branches/${branch?.id}/`}>{branch?.data.title}</a>
        </span>
        <span class="badge">{entry.data.status}</span>
      </p>
      <h1>{entry.data.short}</h1>
      <p class="full-title">{entry.data.title}</p>
      <p class="muted">
        {entry.data.authors && <span>{entry.data.authors} · </span>}
        {entry.data.venue ? `${entry.data.venue}` : entry.data.year}
      </p>
      {
        Object.keys(entry.data.links).length > 0 && (
          <p class="links">
            {Object.entries(entry.data.links).map(([key, url]) => (
              <a href={url} target="_blank" rel="noopener">
                {LINK_LABELS[key] ?? key} ↗
              </a>
            ))}
          </p>
        )
      }
    </header>

    <section class="panel node-summary">
      <h2>{t(lang, 'node.problem')}</h2>
      <p>{entry.data.problem}</p>
      <h2>{t(lang, 'node.coreIdea')}</h2>
      <p>{entry.data.solution}</p>
      {
        entry.data.limitations && (
          <>
            <h2>{t(lang, 'node.limitations')}</h2>
            <p>{entry.data.limitations}</p>
          </>
        )
      }
    </section>

    <section>
      <h2>{t(lang, 'node.place')}</h2>
      {
        outgoing.length > 0 && (
          <>
            <h3>{t(lang, 'node.standsOn')}</h3>
            <ul class="relation-list">
              {outgoing.map((r) => (
                <li>
                  <span class="rel-type">{EDGE_TYPES[r.type].label}</span>
                  <a href={`${root}/nodes/${r.other!.id}/`}>{r.other!.data.short}</a>
                  {r.note && <p class="muted">{r.note}</p>}
                </li>
              ))}
            </ul>
          </>
        )
      }
      {
        incoming.length > 0 && (
          <>
            <h3>{t(lang, 'node.standsOnIt')}</h3>
            <ul class="relation-list">
              {incoming.map((r) => (
                <li>
                  <a href={`${root}/nodes/${r.other.id}/`}>{r.other.data.short}</a>
                  <span class="rel-type">{EDGE_TYPES[r.type].label}</span> {t(lang, 'node.thisWork')}
                  {r.note && <p class="muted">{r.note}</p>}
                </li>
              ))}
            </ul>
          </>
        )
      }
      {outgoing.length === 0 && incoming.length === 0 && (
        <p class="muted">{t(lang, 'node.root')}</p>
      )}
    </section>

    <section>
      {
        post ? (
          <p>
            📖 {t(lang, 'node.readAnalysis')} <a href={`${root}/blog/${post.id}/`}>{post.data.title}</a>
          </p>
        ) : (
          <p class="muted">{t(lang, 'node.seedNotice').replace('{status}', entry.data.status)}</p>
        )
      }
    </section>

    <p><a href={`${root}/`}>{t(lang, 'node.back')}</a></p>
  </article>
</Base>

<style>
  .node-header h1 {
    margin: 0.4rem 0 0.2rem;
  }

  .full-title {
    color: var(--ink-2);
    font-size: 1.05rem;
    margin: 0.2rem 0;
  }

  .links a {
    margin-right: 1rem;
  }

  .node-summary {
    margin: 1.5rem 0;
  }

  .node-summary h2 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 1.1rem 0 0.3rem;
  }

  .node-summary h2:first-child {
    margin-top: 0;
  }

  .relation-list {
    list-style: none;
    padding: 0;
  }

  .relation-list li {
    margin: 0.7rem 0;
    padding-left: 1rem;
    border-left: 2px solid var(--baseline);
  }

  .relation-list p {
    margin: 0.2rem 0 0;
    font-size: 0.9rem;
  }

  .rel-type {
    color: var(--accent);
    font-style: italic;
    margin-right: 0.35em;
  }
</style>
