---
/**
 * The main genealogy panel — two views stacked on top of each other:
 *
 * Timeline (top) — a D3 timeline DAG: x = years (compressed), horizontal
 * lanes grouped by branch, stroke-style-coded relation edges (old → new),
 * gold rings on awarded works, hover focus-mode dimming everything but a
 * node's direct relations. Fully theme-aware: colors are read from CSS
 * custom properties at render time and the view re-renders on `themechange`.
 *
 * 3D (below, always on) — a force graph (three.js) from src/lib/graph3d.js:
 * nodes cluster by lane inside faint bubbles with floating lane labels;
 * same award rings and hover focus; clicking docks an info panel.
 *
 * Both views read /graph.json — generated from src/content/ — so adding
 * branches or nodes requires NO changes to this file. UI strings arrive
 * pre-localized through data attributes.
 */
import { graphStrings, t, type Lang } from '../lib/i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<figure
  class="genealogy panel"
  id="gg-fig"
  data-base={base}
  data-root={`${base}/${lang}`}
  data-i18n={JSON.stringify(graphStrings(lang))}
>
  <div class="gg-legend" id="gg-legend"></div>
  <div class="gg-viewport" id="gg-viewport">
    <svg id="gg-svg" role="img" aria-label="Genealogy of 3D vision works over time"></svg>
    <div class="gg-tooltip" id="gg-tooltip" hidden></div>
  </div>
  <p class="muted gg-hint">
    {t(lang, 'graph.hint2d')}
    <noscript>{t(lang, 'graph.noscript')}</noscript>
  </p>
  <div class="gg-3d-wrap" id="gg-3d-wrap">
    <div class="gg-3d" id="gg-3d"><p class="gg-3d-loading" id="gg-3d-loading"></p></div>
    <aside class="gg-3d-info" id="gg-3d-info" hidden></aside>
  </div>
  <figcaption class="muted gg-hint">{t(lang, 'graph.hint3d')}</figcaption>
</figure>

<script>
  import * as d3 from 'd3';

  const fig = document.getElementById('gg-fig');
  const base = fig.dataset.base;
  const root = fig.dataset.root;
  const STR = JSON.parse(fig.dataset.i18n);

  // read design tokens live so both themes use the same code path
  const tok = (name) => getComputedStyle(document.documentElement).getPropertyValue(name).trim();
  const isLight = () => document.documentElement.dataset.theme === 'light';

  const esc = (s) =>
    String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]);
  const truncate = (s, n) => (s.length > n ? `${s.slice(0, n).trimEnd()}…` : s);

  init().catch((err) => console.error('genealogy graph:', err));

  async function init() {
    const data = await (await fetch(`${base}/graph.json`)).json();

    const branchById = new Map(data.branches.map((b) => [b.id, b]));
    const nodeById = new Map(data.nodes.map((n) => [n.id, n]));
    const bColor = (branchId) => {
      const b = branchById.get(branchId);
      return b ? (isLight() ? b.colorLight : b.color) : tok('--muted');
    };

    // ---- layout (theme-independent, computed once) ----
    const YEAR_W = 112;
    const STACK_GAP = 46; // vertical gap between same-lane, same-year nodes
    const MIN_LANE_H = 92;
    const M = { top: 52, left: 216, right: 48, bottom: 16 };

    const years = [...new Set(data.nodes.map((n) => n.year))].sort((a, b) => a - b);
    // first column is inset by 0.85 steps so centered labels don't slide under the left gutter
    const yearX = new Map(years.map((y, i) => [y, M.left + (i + 0.85) * YEAR_W]));
    const width = M.left + (years.length + 0.7) * YEAR_W + M.right;

    // Lane heights grow with the largest same-year stack in that lane
    const lanes = data.lanes;
    const stackOf = d3.group(data.nodes, (n) => `${n.lane}@${n.year}`);
    const maxStack = new Map();
    for (const [key, members] of stackOf) {
      const lane = key.slice(0, key.lastIndexOf('@'));
      maxStack.set(lane, Math.max(maxStack.get(lane) ?? 1, members.length));
    }
    const laneTop = new Map();
    const laneCenter = new Map();
    let yCursor = M.top;
    for (const l of lanes) {
      const h = Math.max(MIN_LANE_H, (maxStack.get(l.id) ?? 1) * STACK_GAP + 36);
      laneTop.set(l.id, yCursor);
      laneCenter.set(l.id, yCursor + h / 2);
      yCursor += h;
    }
    const height = yCursor + M.bottom;
    const viewH = Math.max(420, Math.min(height, 860));

    // same lane + same year → stack vertically around the lane center
    const pos = new Map();
    for (const [, members] of stackOf) {
      members.forEach((n, i) => {
        pos.set(n.id, {
          x: yearX.get(n.year),
          y: laneCenter.get(n.lane) + (i - (members.length - 1) / 2) * STACK_GAP,
        });
      });
    }

    // One consistent label rule: always centered below the mark; year/author
    // parentheticals dropped (the x-axis already says the year)
    const shortLabel = (s) =>
      String(s)
        .replace(/\s*\([^)]*\)\s*$/, '')
        .replace(/\s+(19|20)\d{2}$/, '');

    const edges = data.edges.filter((e) => pos.has(e.source) && pos.has(e.target));
    if (edges.length < data.edges.length) {
      console.warn(`genealogy: skipped ${data.edges.length - edges.length} edge(s) pointing to missing nodes`);
    }

    // neighborhood map for hover focus-mode (node id → related node ids)
    const nbr = new Map(data.nodes.map((n) => [n.id, new Set([n.id])]));
    for (const e of edges) {
      nbr.get(e.source)?.add(e.target);
      nbr.get(e.target)?.add(e.source);
    }

    const firstLaneOf = new Map();
    lanes.forEach((l) => {
      if (!firstLaneOf.has(l.branch)) firstLaneOf.set(l.branch, l.id);
    });

    const viewport = document.getElementById('gg-viewport');
    const tooltip = document.getElementById('gg-tooltip');
    const svg = d3.select('#gg-svg').attr('height', viewH);

    // edges anchor on the marks' top/bottom within a year and bow slightly
    // left so they never cut through stacked nodes or labels
    const edgePath = (e) => {
      const s = pos.get(e.source);
      const t = pos.get(e.target);
      if (s.x === t.x) {
        const dir = t.y > s.y ? 1 : -1;
        const y0 = s.y + dir * 12;
        const y1 = t.y - dir * 15;
        const bow = Math.min(44, 14 + Math.abs(t.y - s.y) * 0.18);
        return `M${s.x},${y0} C${s.x - bow},${y0 + dir * 8} ${s.x - bow},${y1 - dir * 8} ${s.x},${y1}`;
      }
      const x0 = s.x + 12;
      const x1 = t.x - 15;
      const mx = (x0 + x1) / 2;
      return `M${x0},${s.y} C${mx},${s.y} ${mx},${t.y} ${x1},${t.y}`;
    };

    // ---- theme-aware drawing: everything below re-runs on `themechange` ----
    function renderTimeline() {
      svg.selectAll('*').remove();

      // stroke style per relation type — dash pattern carries the meaning
      // (CVD-safe); "challenges" is the one colored exception (warning red)
      const EDGE_STYLE = {
        fixes: { stroke: tok('--ink-2'), dash: null, width: 2 },
        'builds-on': { stroke: tok('--muted'), dash: null, width: 1.4 },
        independent: { stroke: tok('--muted'), dash: '6 5', width: 1.6 },
        challenges: { stroke: tok('--danger'), dash: '2 4', width: 1.6 },
        revives: { stroke: tok('--muted'), dash: '10 4 2 4', width: 1.6 },
      };

      const defs = svg.append('defs');
      for (const [type, s] of Object.entries(EDGE_STYLE)) {
        defs
          .append('marker')
          .attr('id', `gg-arrow-${type}`)
          .attr('viewBox', '0 -5 10 10')
          .attr('refX', 8)
          .attr('refY', 0)
          .attr('markerWidth', 7)
          .attr('markerHeight', 7)
          .attr('orient', 'auto')
          .append('path')
          .attr('d', 'M0,-5L10,0L0,5')
          .attr('fill', s.stroke);
      }

      const g = svg.append('g');

      g.append('g')
        .selectAll('line')
        .data(years)
        .join('line')
        .attr('x1', (y) => yearX.get(y))
        .attr('x2', (y) => yearX.get(y))
        .attr('y1', M.top)
        .attr('y2', height - M.bottom)
        .attr('stroke', tok('--grid'));

      const sepG = g.append('g');
      lanes.forEach((l, i) => {
        if (i === 0) return;
        const branchBoundary = lanes[i - 1].branch !== l.branch;
        sepG
          .append('line')
          .attr('x1', M.left - 10)
          .attr('x2', width - M.right + 10)
          .attr('y1', laneTop.get(l.id))
          .attr('y2', laneTop.get(l.id))
          .attr('stroke', branchBoundary ? tok('--baseline') : tok('--grid'))
          .attr('stroke-dasharray', branchBoundary ? null : '2 6');
      });

      // ---- edges
      const edgesG = g.append('g').attr('fill', 'none');
      const edgeSel = edgesG
        .selectAll('path.gg-edge')
        .data(edges)
        .join('path')
        .attr('class', 'gg-edge')
        .attr('d', edgePath)
        .attr('stroke', (e) => EDGE_STYLE[e.type].stroke)
        .attr('stroke-width', (e) => EDGE_STYLE[e.type].width)
        .attr('stroke-dasharray', (e) => EDGE_STYLE[e.type].dash)
        .attr('marker-end', (e) => `url(#gg-arrow-${e.type})`);

      // ---- nodes
      const nodesG = g.append('g');
      const nodeSel = nodesG
        .selectAll('g.gg-node')
        .data(data.nodes)
        .join('g')
        .attr('class', 'gg-node')
        .attr('transform', (n) => `translate(${pos.get(n.id).x},${pos.get(n.id).y})`)
        .style('cursor', 'pointer');

      // surface-colored spacer ring so edges never touch the mark
      nodeSel.append('circle').attr('r', 10).attr('fill', tok('--surface'));
      // mark: filled = has an article, hollow = seed awaiting a write-up
      nodeSel
        .append('circle')
        .attr('r', 7)
        .attr('fill', (n) => (n.hasPost || n.status === 'written' ? bColor(n.branch) : tok('--surface')))
        .attr('stroke', (n) => bColor(n.branch))
        .attr('stroke-width', 2);
      // gold ring for awarded / oral / spotlight works
      nodeSel
        .filter((n) => n.award)
        .append('circle')
        .attr('r', 12)
        .attr('fill', 'none')
        .attr('stroke', tok('--award'))
        .attr('stroke-width', 1.6);
      // direct label on every node (the secondary encoding for CVD)
      nodeSel
        .append('text')
        .attr('class', 'gg-node-label')
        .attr('y', 24)
        .attr('text-anchor', 'middle')
        .text((n) => shortLabel(n.short));
      // hover/click target larger than the mark
      nodeSel.append('circle').attr('r', 17).attr('fill', 'transparent');

      // ---- hover focus-mode: dim everything but the direct relations
      function focusNode(id) {
        nodeSel.classed('gg-dim', (n) => !nbr.get(id)?.has(n.id));
        edgeSel.classed('gg-dim', (e) => e.source !== id && e.target !== id);
        edgeHit.classed('gg-dim', () => false);
      }
      function focusEdge(edge) {
        nodeSel.classed('gg-dim', (n) => n.id !== edge.source && n.id !== edge.target);
        edgeSel.classed('gg-dim', (e) => e !== edge);
      }
      function unfocus() {
        nodeSel.classed('gg-dim', false);
        edgeSel.classed('gg-dim', false);
      }

      nodeSel
        .on('click', (_ev, n) => {
          window.location.href = `${root}/nodes/${n.id}/`;
        })
        .on('mousemove', (ev, n) => {
          focusNode(n.id);
          showTip(ev, nodeTipHtml(n));
        })
        .on('mouseleave', () => {
          unfocus();
          hideTip();
        });

      // hover hit area wider than the stroke
      const edgeHit = edgesG
        .selectAll('path.gg-edge-hit')
        .data(edges)
        .join('path')
        .attr('class', 'gg-edge-hit')
        .attr('d', edgePath)
        .attr('stroke', 'transparent')
        .attr('stroke-width', 13)
        .on('mousemove', (ev, e) => {
          focusEdge(e);
          showTip(ev, edgeTipHtml(e));
        })
        .on('mouseleave', () => {
          unfocus();
          hideTip();
        });

      // ---- left gutter (lane + branch names) and year axis: stay put while panning
      const gutter = svg.append('g');
      gutter.append('rect').attr('width', M.left - 14).attr('height', viewH).attr('fill', tok('--surface'));

      const laneLabels = gutter
        .selectAll('text.gg-lane-label')
        .data(lanes)
        .join('text')
        .attr('class', 'gg-lane-label')
        .attr('x', M.left - 26)
        .attr('text-anchor', 'end')
        .text((l) => l.title);

      const branchLabels = gutter
        .selectAll('text.gg-branch-label')
        .data(data.branches.filter((b) => firstLaneOf.has(b.id)))
        .join('text')
        .attr('class', 'gg-branch-label')
        .attr('x', M.left - 26)
        .attr('text-anchor', 'end')
        .attr('fill', (b) => bColor(b.id))
        .text((b) => b.title);

      const axis = svg.append('g');
      axis.append('rect').attr('width', '100%').attr('height', M.top - 16).attr('fill', tok('--surface'));
      const yearLabels = axis
        .selectAll('text')
        .data(years)
        .join('text')
        .attr('class', 'gg-axis-label')
        .attr('y', M.top - 26)
        .attr('text-anchor', 'middle')
        .text((y) => y);

      // ---- zoom/pan: main layer gets the full transform, gutter labels only their own axis
      function applyTransform(t) {
        g.attr('transform', t.toString());
        yearLabels
          .attr('x', (y) => t.applyX(yearX.get(y)))
          .attr('opacity', (y) => (t.applyX(yearX.get(y)) < M.left - 10 ? 0 : 1));
        laneLabels.attr('y', (l) => t.applyY(laneCenter.get(l.id)) + 4);
        // branch heading clamps to stay above its first lane's label at ANY zoom
        branchLabels.attr('y', (b) => {
          const first = firstLaneOf.get(b.id);
          return Math.min(t.applyY(laneTop.get(first)) + 20, t.applyY(laneCenter.get(first)) - 12);
        });
      }

      // default view: fit the WHOLE genealogy inside the box
      const fitK = Math.min(
        1,
        ((viewport.clientWidth || 1100) - M.left) / (width - M.left),
        (viewH - M.top) / (height - M.top),
      );
      const zoomBehavior = d3
        .zoom()
        .scaleExtent([Math.min(0.4, fitK), 2.2])
        .translateExtent([
          [-120, -120],
          [width + 120, height + 120],
        ])
        .on('zoom', (ev) => applyTransform(ev.transform));
      svg.call(zoomBehavior);
      svg.call(
        zoomBehavior.transform,
        d3.zoomIdentity.translate(M.left * (1 - fitK), M.top * (1 - fitK)).scale(fitK),
      );

      // ---- legend
      const sample = bColor(data.branches[0]?.id);
      document.getElementById('gg-legend').innerHTML = `
        <div class="legend-group">
          ${data.branches
            .map(
              (b) =>
                `<span class="chip"><span class="dot" style="background:${bColor(b.id)}"></span>${esc(b.title)}</span>`,
            )
            .join('')}
        </div>
        <div class="legend-group">
          ${Object.entries(data.edgeTypes)
            .map(([type, meta]) => {
              const s = EDGE_STYLE[type];
              if (!s) return '';
              return `<span class="legend-item"><svg width="34" height="10" aria-hidden="true"><line x1="1" y1="5" x2="33" y2="5" stroke="${s.stroke}" stroke-width="${s.width}"${s.dash ? ` stroke-dasharray="${s.dash}"` : ''}/></svg>${esc(meta.label)}</span>`;
            })
            .join('')}
        </div>
        <div class="legend-group">
          <span class="legend-item"><svg width="14" height="14" aria-hidden="true"><circle cx="7" cy="7" r="5" fill="${sample}"/></svg>${esc(STR.hasArticle)}</span>
          <span class="legend-item"><svg width="14" height="14" aria-hidden="true"><circle cx="7" cy="7" r="5" fill="${tok('--surface')}" stroke="${sample}" stroke-width="2"/></svg>${esc(STR.seed)}</span>
          <span class="legend-item"><svg width="16" height="16" aria-hidden="true"><circle cx="8" cy="8" r="4" fill="${sample}"/><circle cx="8" cy="8" r="7" fill="none" stroke="${tok('--award')}" stroke-width="1.6"/></svg>${esc(STR.award)}</span>
        </div>`;
    }

    // ---- tooltip
    function showTip(ev, html) {
      tooltip.innerHTML = html;
      tooltip.hidden = false;
      const r = viewport.getBoundingClientRect();
      let x = ev.clientX - r.left + 14;
      let y = ev.clientY - r.top + 12;
      if (x + tooltip.offsetWidth > r.width - 8) x = ev.clientX - r.left - tooltip.offsetWidth - 12;
      if (y + tooltip.offsetHeight > r.height - 8) y = ev.clientY - r.top - tooltip.offsetHeight - 10;
      tooltip.style.left = `${x}px`;
      tooltip.style.top = `${y}px`;
    }
    function hideTip() {
      tooltip.hidden = true;
    }

    const nodeTipHtml = (n) => `
      <strong>${esc(n.short)}</strong>
      <span class="tip-meta">${n.year}${n.venue ? ` · ${esc(n.venue)}` : ''}</span>
      <p>${esc(truncate(n.problem, 170))}</p>
      <span class="tip-hint">${esc(STR.tipOpen)}</span>`;

    const edgeTipHtml = (e) => {
      const s = nodeById.get(e.source);
      const t = nodeById.get(e.target);
      const label = data.edgeTypes[e.type]?.label ?? e.type;
      return `
        <strong>${esc(t.short)}</strong> <em class="tip-rel">${esc(label)}</em> <strong>${esc(s.short)}</strong>
        ${e.note ? `<p>${esc(e.note)}</p>` : ''}`;
    };

    renderTimeline();
    window.addEventListener('themechange', renderTimeline);

    // ---- 3D view, always on below the timeline
    const el3d = document.getElementById('gg-3d');
    const info3d = document.getElementById('gg-3d-info');
    document.getElementById('gg-3d-loading').textContent = STR.loading3d;
    document.getElementById('gg-3d-wrap').style.height = `${Math.max(560, Math.min(viewH, 820))}px`;
    try {
      const { mount3D } = await import('../lib/graph3d.js');
      el3d.innerHTML = '';
      const g3d = mount3D({ el: el3d, infoEl: info3d, data, root, strings: STR });
      window.addEventListener('themechange', () => g3d.applyTheme());
    } catch (err) {
      el3d.innerHTML = `<p class="gg-3d-loading">${esc(STR.error3d)}</p>`;
      console.error('genealogy 3d:', err);
    }
  }
</script>

<style is:global>
  .genealogy {
    margin: 1.5rem 0;
    padding: 1rem;
    /* break out of the 1100px container: the graphs deserve the screen */
    width: min(96vw, 1680px);
    position: relative;
    left: 50%;
    transform: translateX(-50%);
  }

  .gg-viewport {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
  }

  #gg-svg {
    display: block;
    width: 100%;
    background: var(--surface);
  }

  .gg-edge {
    opacity: 0.7;
    transition: opacity 0.15s;
  }

  .gg-node {
    transition: opacity 0.15s;
  }

  .gg-node.gg-dim {
    opacity: 0.12;
  }

  .gg-edge.gg-dim {
    opacity: 0.06;
  }

  .gg-node-label {
    font-family: var(--font);
    font-size: 11px;
    fill: var(--ink-2);
    paint-order: stroke;
    stroke: var(--surface);
    stroke-width: 3px;
    stroke-linejoin: round;
  }

  .gg-lane-label {
    font-family: var(--font);
    font-size: 12px;
    fill: var(--ink-2);
  }

  .gg-branch-label {
    font-family: var(--font);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .gg-axis-label {
    font-family: var(--font);
    font-size: 12px;
    fill: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  .gg-tooltip {
    position: absolute;
    max-width: 300px;
    background: var(--tooltip-bg);
    border: 1px solid var(--ring);
    border-radius: 8px;
    padding: 0.6rem 0.8rem;
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--ink-2);
    pointer-events: none;
    z-index: 10;
  }

  .gg-tooltip strong {
    color: var(--ink);
  }

  .gg-tooltip p {
    margin: 0.35rem 0;
  }

  .gg-tooltip .tip-meta {
    display: block;
    color: var(--muted);
    font-size: 0.76rem;
  }

  .gg-tooltip .tip-rel {
    color: var(--accent);
    font-style: italic;
  }

  .gg-tooltip .tip-hint {
    color: var(--muted);
    font-size: 0.74rem;
  }

  .gg-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    padding: 0.25rem 0.25rem 0.9rem;
    align-items: center;
  }

  .gg-legend .legend-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    align-items: center;
  }

  .gg-legend .legend-group + .legend-group {
    border-left: 1px solid var(--grid);
    padding-left: 1.25rem;
  }

  .gg-legend .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .gg-hint {
    padding: 0.7rem 0 0;
    margin: 0 0 1rem;
    font-size: 0.8rem;
  }

  .genealogy figcaption.gg-hint {
    margin: 0;
  }

  /* ---- 3D view (always on, below the timeline) ---- */
  .gg-3d-wrap {
    display: flex;
    gap: 0.75rem;
    background: var(--page);
    border-radius: 8px;
  }

  .gg-3d {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    border-radius: 8px;
  }

  .gg-3d-loading {
    color: var(--muted);
    text-align: center;
    padding-top: 4rem;
    font-size: 0.9rem;
  }

  .gg-3d-tip {
    max-width: 260px;
    font-family: var(--font);
    font-size: 12px;
    line-height: 1.45;
    color: var(--ink-2);
    background: var(--tooltip-bg);
    padding: 7px 10px;
    border-radius: 6px;
    border: 1px solid var(--ring);
  }

  .gg-3d-tip b {
    color: var(--ink);
  }

  .gg-3d-tip span {
    display: block;
    color: var(--muted);
    font-size: 11px;
  }

  .gg-3d-tip p {
    margin: 4px 0 0;
  }

  .gg-3d-info {
    width: 300px;
    flex: none;
    background: var(--surface);
    border: 1px solid var(--ring);
